{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "Keystone OS",
  "short_name": "Keystone",
  "description": "Vos outils métier — QR dynamiques, formulaires, agent IA, audit web, réseaux sociaux — dans un OS modulaire et souverain.",
  "lang": "fr",
  "dir": "ltr",
  "start_url": "/app?ks_launch=1",
  "scope": "/",
  "display": "standalone",
  "orientation": "landscape",
  "background_color": "#07102a",
  "theme_color": "#07102a",
  "categories": ["productivity", "business"],
  "icons": [
    { "src": "./favicon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "./favicon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "./favicon-192-maskable.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "./favicon-512-maskable.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "shortcuts": [
    {
      "name": "Ouvrir le Dashboard",
      "short_name": "Dashboard",
      "description": "Accéder au dashboard Keystone OS",
      "url": "/app?ks_launch=1",
      "icons": [{ "src": "./favicon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],
  "screenshots": [],
  "related_applications": [],
  "prefer_related_applications": false
}
