{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "version": 2,

  "rewrites": [
    { "source": "/app",         "destination": "/app.html"         },
    { "source": "/admin",       "destination": "/admin.html"       },
    { "source": "/auth/magic",  "destination": "/auth-magic"       },
    { "source": "/f/(.*)",      "destination": "/form?s=$1"        },
    { "source": "/a/(.*)",      "destination": "/agent?s=$1"       },
    { "source": "/sonnette-invite", "destination": "/sonnette-invite.html" }
  ],

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    },
    {
      "source": "/app/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/src/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/app/vendor/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(lottie.min.js|sablier.json|keystone-logo.svg|keystone-puce.svg|keystone-puce-blanc.svg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/LOGOS/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/RESOURCES/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/K_STORE_ASSETS/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/app.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/form.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/agent.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security",           "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval' https://esm.sh https://*.esm.sh https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; media-src 'self' blob: https://keystone-os-api.keystone-os.workers.dev; connect-src 'self' https://keystone-os-api.keystone-os.workers.dev https://esm.sh https://*.esm.sh https://unpkg.com; worker-src 'self' blob:; frame-src 'self' https://buy.stripe.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://buy.stripe.com; report-uri https://keystone-os-api.keystone-os.workers.dev/api/csp-report" },
        { "key": "X-Content-Type-Options",              "value": "nosniff" },
        { "key": "X-Frame-Options",                     "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",                     "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",                  "value": "camera=(), microphone=(self), geolocation=()" }
      ]
    }
  ],

  "trailingSlash": false,
  "cleanUrls": true
}
